generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      String   @default("user") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  anggota Anggota?

  @@map("users")
}

model KelompokUpa {
  id           BigInt   @id @default(autoincrement())
  namaKelompok String   @map("nama_kelompok") @db.VarChar(100)
  ketuaId      BigInt?  @map("ketua_id")
  wilayah      String?  @db.VarChar(100)
  jadwalRutin  String?  @map("jadwal_rutin") @db.VarChar(100)
  deskripsi    String?  @db.Text

  ketua             Anggota?            @relation("KetuaKelompok", fields: [ketuaId], references: [id])
  anggota            Anggota[]
  absensiKelompok    AbsensiKelompok[]
  jadwalUpa          JadwalUpa[]
  kasKelompok        KasKelompok[]

  @@map("kelompok_upa")
}

model KasKelompok {
  id            BigInt   @id @default(autoincrement())
  kelompokId    BigInt   @map("kelompok_id")
  anggotaId     BigInt?  @map("anggota_id")
  tipe          String   @db.VarChar(10)
  nominal       Int
  keterangan    String?  @db.Text
  tanggal       DateTime @default(now()) @db.Date

  kelompok      KelompokUpa @relation(fields: [kelompokId], references: [id])
  anggota       Anggota?    @relation(fields: [anggotaId], references: [id])

  @@map("kas_kelompok")
}

model Anggota {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @unique @map("user_id")
  kelompokId    BigInt?  @map("kelompok_id")

  namaLengkap   String   @map("nama_lengkap") @db.VarChar(100)
  nik           String?  @unique @db.VarChar(20)
  noHp          String?  @map("no_hp") @db.VarChar(20)
  tempatLahir   String?  @map("tempat_lahir") @db.VarChar(50)
  tanggalLahir  DateTime? @map("tanggal_lahir") @db.Date
  jenisKelamin  String?  @map("jenis_kelamin") @db.VarChar(1)
  alamat        String?  @db.Text
  pendidikan    String?  @db.VarChar(50)
  pekerjaan     String?  @db.VarChar(100)
  desil         Int?
  status        String   @default("aktif") @db.VarChar(20)
  tahunGabung   Int?     @map("tahun_gabung")

  user               User?               @relation(fields: [userId], references: [id])
  kelompok           KelompokUpa?        @relation(fields: [kelompokId], references: [id])
  kelompokDipimpin   KelompokUpa[]       @relation("KetuaKelompok")

  absensiKelompok    AbsensiKelompok[]
  absensiKegiatan    AbsensiKegiatan[]
  kasKelompok        KasKelompok[]

  @@map("anggota")
}

model Form {
  id                BigInt   @id @default(autoincrement())
  judul             String   @db.VarChar(200)
  deskripsi         String?  @db.Text
  status            String   @default("aktif") @db.VarChar(20)
  warnaAksen        String   @default("#10b981") @map("warna_aksen") @db.VarChar(20)
  headerGambar      String?  @map("header_gambar") @db.VarChar(500)
  limitSatuResponse Boolean  @default(false) @map("limit_satu_response")
  allowEdit         Boolean  @default(false) @map("allow_edit")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdBy         BigInt?  @map("created_by")

  pertanyaan    PertanyaanForm[]
  response      ResponseForm[]

  @@map("form")
}

model PertanyaanForm {
  id            BigInt  @id @default(autoincrement())
  formId        BigInt  @map("form_id")
  tipe          String  @db.VarChar(30)
  pertanyaan    String  @db.Text
  isWajib       Boolean @default(true) @map("is_wajib")
  urutan        Int     @default(0)
  opsi          String? @db.Text
  validasi      String? @db.Text
  fileMaxSize   Int?    @map("file_max_size")
  fileFormat    String? @map("file_format") @db.VarChar(100)
  scaleMin      Int?    @default(1) @map("scale_min")
  scaleMax      Int?    @default(5) @map("scale_max")
  scaleLabelMin String? @map("scale_label_min") @db.VarChar(100)
  scaleLabelMax String? @map("scale_label_max") @db.VarChar(100)

  form      Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  jawaban   JawabanResponse[]

  @@map("pertanyaan_form")
}

model ResponseForm {
  id             BigInt   @id @default(autoincrement())
  formId         BigInt   @map("form_id")
  respondenNama  String?  @map("responden_nama") @db.VarChar(100)
  respondenEmail String?  @map("responden_email") @db.VarChar(100)
  uniqueId       String?  @map("unique_id") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  form      Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  jawaban   JawabanResponse[]

  @@map("response_form")
}

model JawabanResponse {
  id            BigInt  @id @default(autoincrement())
  responseId    BigInt  @map("response_id")
  pertanyaanId  BigInt  @map("pertanyaan_id")
  jawaban       String? @db.Text

  response    ResponseForm    @relation(fields: [responseId], references: [id], onDelete: Cascade)
  pertanyaan  PertanyaanForm  @relation(fields: [pertanyaanId], references: [id])

  @@map("jawaban_response")
}

model Kegiatan {
  id               BigInt  @id @default(autoincrement())
  namaKegiatan     String  @map("nama_kegiatan") @db.VarChar(150)
  jenis            String? @db.VarChar(50)
  tanggal          DateTime? @db.Date
  jamMulai         String? @map("jam_mulai") @db.VarChar(10)
  jamSelesai       String? @map("jam_selesai") @db.VarChar(10)
  lokasi           String? @db.VarChar(150)
  mapsUrl          String? @map("maps_url") @db.VarChar(500)
  gambar           String? @db.VarChar(500)
  poster           String? @db.VarChar(500)
  penanggungJawab  BigInt? @map("penanggung_jawab")
  deskripsi        String? @db.Text

  absensiKegiatan AbsensiKegiatan[]

  @@map("kegiatan")
}

model AbsensiKelompok {
  id          BigInt  @id @default(autoincrement())
  kelompokId  BigInt? @map("kelompok_id")
  anggotaId   BigInt? @map("anggota_id")
  tanggal     DateTime? @db.Date
  status      String  @default("hadir") @db.VarChar(20)

  kelompok KelompokUpa? @relation(fields: [kelompokId], references: [id])
  anggota  Anggota?     @relation(fields: [anggotaId], references: [id])

  @@map("absensi_kelompok")
}

model AbsensiKegiatan {
  id          BigInt  @id @default(autoincrement())
  kegiatanId  BigInt? @map("kegiatan_id")
  anggotaId   BigInt? @map("anggota_id")
  status      String  @default("hadir") @db.VarChar(20)

  kegiatan Kegiatan? @relation(fields: [kegiatanId], references: [id])
  anggota  Anggota?  @relation(fields: [anggotaId], references: [id])

  @@map("absensi_kegiatan")
}

model JadwalUpa {
  id          BigInt  @id @default(autoincrement())
  kelompokId  BigInt? @map("kelompok_id")
  hari        String? @db.VarChar(20)
  waktu       String? @db.VarChar(20)
  tempat      String? @db.VarChar(150)
  mapsUrl     String? @map("maps_url") @db.VarChar(500)
  aktivitas   String? @db.Text

  kelompok KelompokUpa? @relation(fields: [kelompokId], references: [id])

  @@map("jadwal_upa")
}
